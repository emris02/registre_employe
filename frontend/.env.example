# ============================================
# FRONTEND ENVIRONMENT CONFIGURATION
# Copy to .env.local for development (never commit .env.local)
# For Netlify: set these in Site settings > Environment variables
# ============================================

# Local development (uses Vite proxy)
VITE_API_URL=/api

# Production - Render Backend URL
# Remplacez par votre URL Render:
# VITE_API_URL=https://registre-employe.onrender.com/api

# Netlify deployment URL (optional, for reference)
# VITE_FRONTEND_URL=https://votre-site.netlify.app

# ============================================
# SECURITY CONFIGURATION (Scan QR)
# ============================================
# VITE_SCAN_SESSION_TIMEOUT=3600000  # 1 heure en millisecondes
# VITE_SCAN_MAX_DEVICES=5
# VITE_SCAN_DEVICE_TOKEN_EXPIRY=86400000  # 24 heures
# VITE_SCAN_ENCRYPTION_KEY=votre_clé_de_chiffrement_secrète
# VITE_SCAN_SESSION_SECRET=votre_secret_de_session

