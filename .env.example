# Configuration Supabase
# Copiez ce fichier en .env et remplacez les valeurs par vos clés Supabase

# URL de votre projet Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Clé anonyme de votre projet Supabase
VITE_SUPABASE_ANON_KEY=your-anon-key

# Configuration pour le backend
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Configuration PHP (fallback)
PHP_API_URL=http://localhost/pointage/registrar/api

# Port du backend
PORT=3001
